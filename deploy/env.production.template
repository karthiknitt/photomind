# PhotoMind — Production Environment Variables
#
# Copy this file to /home/karthik/photomind/.env.production on the VPS.
# That path is gitignored — never commit the real file.
# It is sourced by photomind-frontend.service via EnvironmentFile=
#
# After editing, restart the frontend:
#   sudo systemctl restart photomind-frontend

# ─── Database ───────────────────────────────────────────────────────────────

DATABASE_PATH=/home/karthik/photomind/photomind.db

# ─── Thumbnails ─────────────────────────────────────────────────────────────

THUMBNAILS_PATH=/home/karthik/photomind/thumbnails

# ─── CLIP semantic search bridge ────────────────────────────────────────────
# The Python FastAPI service that serves CLIP embeddings.
# If not running, search falls back to text-only mode gracefully.

CLIP_BRIDGE_URL=http://localhost:8765

# ─── Next.js ────────────────────────────────────────────────────────────────

NEXT_TELEMETRY_DISABLED=1
PORT=3003
